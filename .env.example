# === Meta / WhatsApp Cloud API ===
# De developers.facebook.com → App Doppel → Settings → Basic
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=doppel_wh_verify_2026
META_API_VERSION=v21.0
META_API_RETRIES=3
META_API_RETRY_DELAY_MS=300
# PIN de registro del número en WhatsApp Cloud API (puedes dejarlo en 000000)
WA_REGISTRATION_PIN=000000

# === Supabase ===
# De supabase.com → proyecto → Settings → API
SUPABASE_URL=
# Debe ser la key service_role (secret). También se acepta SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=

# === Encriptación ===
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === CORS ===
# Orígenes permitidos (JSON array o lista separada por comas)
ALLOWED_ORIGINS=["https://doppel.lat"]

# === Bot de IA (Agno in-process con Claude) ===
# Interruptor del bot: si AI_CORE_URL queda vacío, el agente NO responde.
# En docker compose este valor lo fija compose.yaml a "enabled".
AI_CORE_URL=enabled
# Clave de Anthropic — sin ella el bot no puede responder.
ANTHROPIC_API_KEY=
ANTHROPIC_API_RETRIES=2
# Modelo Claude por defecto del agente Agno
AI_DEFAULT_MODEL=claude-sonnet-4-20250514
# OpenAI — solo se usa Whisper para transcribir notas de voz de WhatsApp
OPENAI_API_KEY=
# Postgres de Agno (historial/memoria del agente).
# En docker compose este valor lo fija compose.yaml apuntando al servicio agno-postgres.
# Para correr local fuera de compose: postgresql+psycopg://ai:ai@localhost:5532/ai
AGNO_DB_URL=

# === Asistpro WhatsApp gateway ===
# phone_number_id que saltan el flujo de Doppel y van a n8n
ASISTPRO_PHONE_NUMBER_IDS=[]
ASISTPRO_N8N_WEBHOOK_URL=
ASISTPRO_WEBHOOK_SECRET=
ASISTPRO_SEND_API_KEY=
