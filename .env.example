# Meta App — de developers.facebook.com → App Doppel → Settings → Basic
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=doppel_wh_verify_2026
META_API_VERSION=v21.0

# Supabase — de supabase.com → proyecto → Settings → API
SUPABASE_URL=
# Debe ser la key service_role (secret). Tambien se acepta SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=

# Encriptación — generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# PIN de registro de número en WhatsApp Cloud API (puedes dejarlo en 000000)
WA_REGISTRATION_PIN=000000

# CORS — orígenes permitidos (JSON array o lista separada por comas)
ALLOWED_ORIGINS=["https://doppel.lat"]

# Anthropic — dejar vacío para deshabilitar el bot de IA
ANTHROPIC_API_KEY=
# Número de mensajes previos que el bot usa como contexto
AI_CONTEXT_MESSAGES=20
META_API_RETRIES=3
META_API_RETRY_DELAY_MS=300
ANTHROPIC_API_RETRIES=2

# AI core interno - si AI_CORE_URL queda vacio, no responde el agente
AI_CORE_URL=http://ai-core:8000
AI_CORE_TOKEN=change-me-ai-core-secret
AI_CORE_TIMEOUT_SECONDS=120

# Token que ai-core debe usar para llamar tools internas de Doppel
DOPPEL_INTERNAL_API_TOKEN=change-me-doppel-internal-secret

# Ai-core - runtime interno (Agno + Gemini)
AI_CORE_API_TOKEN=change-me-ai-core-secret
AI_CORE_DB_URL=postgresql+psycopg://ai:ai@ai-core-postgres:5432/ai_core
DOPPEL_API_URL=http://doppel-api:8000
# Gemini (modelo barato y multimodal del agente Agno)
GOOGLE_API_KEY=
AI_CORE_GEMINI_MODEL=gemini-2.0-flash-001
AI_CORE_NUM_HISTORY_RUNS=10
# Echo de plomería: si =true, el ai-core responde "tenant/user" sin llamar a Gemini.
AI_CORE_ECHO=false

# Compatibilidad temporal con deploys viejos: tambien se aceptan NANOBOT_RUNTIME_*
NANOBOT_RUNTIME_URL=
NANOBOT_RUNTIME_TOKEN=
NANOBOT_RUNTIME_TIMEOUT_SECONDS=

# Asistpro WhatsApp gateway - phone_number_id completos que saltan el flujo Doppel
ASISTPRO_PHONE_NUMBER_IDS=[]
ASISTPRO_N8N_WEBHOOK_URL=
ASISTPRO_WEBHOOK_SECRET=
ASISTPRO_SEND_API_KEY=
